# Copia este archivo como .env y rellena los valores:
#   cp .env.example .env

# ── API Keys ──────────────────────────────────────────────────────────────────
# Al menos una es requerida para cover letters y análisis ATS.
# Gemini es gratuito (1M tokens/día): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Claude (Anthropic) — se usa si GEMINI_API_KEY no está configurada
ANTHROPIC_API_KEY=

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# App Password de Gmail para resumen diario y cover letters.
# Genera uno en: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# ── Configuración de usuario (sobreescriben config.yaml) ─────────────────────
# USER_NAME=Tu Nombre
# USER_EMAIL=tu@email.com
# USER_PHONE=+52 ...
