# Credenciales sensibles — copia este archivo como .env y rellena los valores
# cp .env.example .env

# Contraseña de aplicación de Gmail (16 caracteres, sin espacios)
# Genera una en: myaccount.google.com/security → Contraseñas de aplicaciones
GMAIL_APP_PASSWORD=

# API Key de Anthropic (opcional si ya está en config.yaml)
# ANTHROPIC_API_KEY=sk-ant-...
